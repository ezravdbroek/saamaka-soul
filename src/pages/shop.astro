---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Shop - Sáamaka Soul Trust">
	<Header />
	<main>
		<section class="hero">
			<div class="hero-container">
				<h1>Spiritual T-Shirts</h1>
				<p class="tagline">From Shadow To Self</p>
			</div>
		</section>

		<section class="story">
			<div class="story-container">
				<div class="story-content">
					<h2>F.S.T.S.</h2>
					<p class="subtitle">Het verhaal achter de Zwarte T-shirts</p>

					<div class="story-text">
						<p class="lead">In het donker begint alles.</p>
						<p>
							Niet alleen het universum. Niet alleen het leven in de baarmoeder. Maar ook groei, zelfreflectie en transformatie.
						</p>
						<p>
							Onze t-shirts zijn zwart - niet omdat zwart 'gewoon mooi' is, maar omdat het donker de plek is waar je jezelf tegenkomt. Waar je vragen stelt in plaats van antwoorden uitspuwt. Waar je leert, struikelt, opstaat en jezelf opnieuw vormgeeft.
						</p>
						<p>
							Elke print op onze t-shirts - of het nu een tekst is die je wakker schudt, of een beeld dat je laat nadenken - is bedoeld om een gesprek te starten. Niet met de wereld, maar eerst met jezelf.
						</p>
					</div>
				</div>
				<div class="story-image">
					<img src="https://images.unsplash.com/photo-1503341504253-dff4815485f1?w=500&h=600&fit=crop" alt="Black T-shirt" />
				</div>
			</div>
		</section>

		<section class="belief">
			<div class="belief-container">
				<p class="belief-intro">Want wij geloven:</p>
				<blockquote>
					<p>Je vindt licht niet door het te zoeken in de zon,</p>
					<p>Je vindt licht door het aan te steken in het donker.</p>
				</blockquote>
			</div>
		</section>

		<section class="pricing">
			<div class="pricing-container">
				<h2>T-Shirts</h2>
				<div class="price-card">
					<div class="price">€88,-</div>
					<p class="price-note">8 per seizoen zijn Exclusief Limited Edition</p>
					<p class="price-detail">(dus komen niet meer terug)</p>
				</div>
			</div>
		</section>

		<section class="collection">
			<div class="collection-container">
				<h2>Collectie</h2>
				<div class="coming-soon">
					<p>Binnenkort beschikbaar</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		background-color: #000000;
		padding: 5rem 4rem;
		text-align: center;
	}

	.hero-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	h1 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 4rem;
		font-weight: 400;
		font-style: italic;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-style: italic;
		color: #c9a227;
	}

	.story {
		background-color: #000000;
		padding: 4rem;
	}

	.story-container {
		display: grid;
		grid-template-columns: 1fr 400px;
		gap: 3rem;
		max-width: 1100px;
		margin: 0 auto;
		align-items: center;
	}

	.story-content h2 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 3rem;
		font-weight: 400;
		color: #c9a227;
		margin-bottom: 0.5rem;
	}

	.story-content .subtitle {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.25rem;
		font-style: italic;
		color: #a0a0a0;
		margin-bottom: 2rem;
	}

	.story-text .lead {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.75rem;
		font-style: italic;
		color: #ffffff;
		margin-bottom: 1.5rem;
	}

	.story-text p {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		font-weight: 300;
		line-height: 1.8;
		color: #ffffff;
		margin-bottom: 1.5rem;
	}

	.story-image img {
		width: 100%;
		height: auto;
		filter: grayscale(100%);
		object-fit: cover;
	}

	.belief {
		background-color: #000000;
		padding: 5rem 4rem;
		border-top: 1px solid #1a1a1a;
		border-bottom: 1px solid #1a1a1a;
	}

	.belief-container {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.belief-intro {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		color: #a0a0a0;
		margin-bottom: 2rem;
	}

	.belief blockquote {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2rem;
		font-style: italic;
		color: #c9a227;
		line-height: 1.6;
	}

	.belief blockquote p {
		margin: 0.5rem 0;
	}

	.pricing {
		background-color: #000000;
		padding: 5rem 4rem;
	}

	.pricing-container {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
	}

	.pricing h2 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2.5rem;
		font-weight: 400;
		color: #ffffff;
		margin-bottom: 3rem;
	}

	.price-card {
		max-width: 400px;
		margin: 0 auto;
		padding: 3rem;
		border: 1px solid #c9a227;
	}

	.price {
		font-family: 'Cormorant Garamond', serif;
		font-size: 3.5rem;
		font-weight: 400;
		color: #c9a227;
		margin-bottom: 1rem;
	}

	.price-note {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.price-detail {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: #a0a0a0;
	}

	.collection {
		background-color: #000000;
		padding: 5rem 4rem;
		border-top: 1px solid #1a1a1a;
	}

	.collection-container {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
	}

	.collection h2 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2.5rem;
		font-weight: 400;
		color: #ffffff;
		margin-bottom: 3rem;
	}

	.coming-soon {
		padding: 4rem;
		border: 1px dashed #333;
	}

	.coming-soon p {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		color: #666;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 3rem 1.5rem;
		}

		h1 {
			font-size: 2.5rem;
		}

		.story {
			padding: 2rem 1.5rem;
		}

		.story-container {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.story-image {
			order: -1;
			justify-self: center;
		}

		.story-image img {
			max-width: 280px;
		}

		.story-content {
			text-align: center;
		}

		.story-content h2 {
			font-size: 2rem;
		}

		.story-text .lead {
			font-size: 1.5rem;
		}

		.belief {
			padding: 3rem 1.5rem;
		}

		.belief blockquote {
			font-size: 1.5rem;
		}

		.pricing {
			padding: 3rem 1.5rem;
		}

		.price-card {
			padding: 2rem;
		}

		.price {
			font-size: 2.5rem;
		}

		.collection {
			padding: 3rem 1.5rem;
		}
	}
</style>
