---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Book a Session - Sáamaka Soul Trust">
	<Header />
	<main>
		<section class="hero">
			<div class="hero-container">
				<span class="subtitle">Coaching</span>
				<h1>Book a session</h1>
				<p class="tagline">Begin je reis naar zelfontdekking</p>
				<div class="hero-line"></div>
			</div>
		</section>

		<section class="booking-info">
			<div class="booking-container">
				<div class="session-details">
					<h2>1 op 1 coaching sessie</h2>
					<div class="price">€144,- <span>per uur</span></div>
					<p class="duration">Sessies duren 2 uur</p>

					<div class="features">
						<div class="feature">
							<span class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></span>
							<p>Persoonlijke begeleiding</p>
						</div>
						<div class="feature">
							<span class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></span>
							<p>Veilige en vertrouwelijke omgeving</p>
						</div>
						<div class="feature">
							<span class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></span>
							<p>Op maat gemaakte aanpak</p>
						</div>
						<div class="feature">
							<span class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></span>
							<p>Online of fysiek mogelijk</p>
						</div>
					</div>
				</div>

				<div class="contact-form">
					<h3>Neem contact op</h3>
					<p class="form-intro">Vul het formulier in en ik neem zo snel mogelijk contact met je op om een sessie in te plannen.</p>

					<form>
						<div class="form-group">
							<label for="name">Naam</label>
							<input type="text" id="name" name="name" required />
						</div>
						<div class="form-group">
							<label for="email">E-mail</label>
							<input type="email" id="email" name="email" required />
						</div>
						<div class="form-group">
							<label for="phone">Telefoonnummer</label>
							<input type="tel" id="phone" name="phone" />
						</div>
						<div class="form-group">
							<label for="message">Bericht</label>
							<textarea id="message" name="message" rows="4" placeholder="Vertel iets over jezelf en wat je zoekt..."></textarea>
						</div>
						<button type="submit" class="submit-button">Verstuur</button>
					</form>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		background-color: #000000;
		padding: 5rem 4rem;
		text-align: center;
	}

	.hero-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	h1 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 4rem;
		font-weight: 400;
		font-style: italic;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		color: #c9a227;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		display: block;
		margin-bottom: 1rem;
	}

	.tagline {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-style: italic;
		color: #a0a0a0;
		margin-bottom: 1.5rem;
	}

	.hero-line {
		width: 60px;
		height: 1px;
		background-color: #c9a227;
		margin: 0 auto;
	}

	.booking-info {
		background-color: #000000;
		padding: 4rem;
	}

	.booking-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		max-width: 1100px;
		margin: 0 auto;
	}

	.session-details {
		padding: 2rem;
		border: 1px solid #1a1a1a;
	}

	.session-details h2 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 2rem;
		font-weight: 400;
		color: #ffffff;
		margin-bottom: 1.5rem;
	}

	.price {
		font-family: 'Cormorant Garamond', serif;
		font-size: 3rem;
		color: #c9a227;
		margin-bottom: 0.5rem;
	}

	.price span {
		font-size: 1.25rem;
		color: #a0a0a0;
	}

	.duration {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		color: #ffffff;
		margin-bottom: 2rem;
	}

	.features {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.feature {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.feature .icon {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.feature p {
		font-family: 'Inter', sans-serif;
		font-size: 0.95rem;
		color: #ffffff;
	}

	.contact-form {
		padding: 2rem;
		border: 1px solid #c9a227;
	}

	.contact-form h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.75rem;
		font-weight: 400;
		color: #ffffff;
		margin-bottom: 1rem;
	}

	.form-intro {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: #a0a0a0;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	.form-group label {
		display: block;
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		box-sizing: border-box;
		padding: 0.75rem 1rem;
		background-color: #0a0a0a;
		border: 1px solid #333;
		color: #ffffff;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		transition: border-color 0.3s ease;
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #c9a227;
	}

	.form-group textarea {
		resize: vertical;
	}

	.submit-button {
		width: 100%;
		padding: 1rem;
		background-color: transparent;
		border: 1px solid #c9a227;
		color: #ffffff;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.submit-button:hover {
		background-color: #c9a227;
		color: #000000;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 3rem 1.5rem;
		}

		h1 {
			font-size: 2.5rem;
		}

		.booking-info {
			padding: 2rem 1.5rem;
		}

		.booking-container {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.session-details,
		.contact-form {
			padding: 1.5rem;
		}

		.price {
			font-size: 2.5rem;
		}
	}
</style>
