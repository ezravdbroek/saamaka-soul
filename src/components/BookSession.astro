<section class="book-session">
	<div class="book-container">
		<h2>Book a session</h2>
		<a href="/booking" class="book-button">Book a session</a>
	</div>
</section>

<style>
	.book-session {
		padding: 5rem 4rem;
		background-color: #000000;
		border-top: 1px solid #1a1a1a;
	}

	.book-container {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
	}

	h2 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 3rem;
		font-weight: 400;
		color: #ffffff;
		margin-bottom: 2rem;
	}

	.book-button {
		display: inline-block;
		padding: 1rem 2rem;
		border: 1px solid #c9a227;
		color: #ffffff;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		font-weight: 400;
		background: transparent;
		transition: all 0.3s ease;
	}

	.book-button:hover {
		background-color: #c9a227;
		color: #000000;
	}

	@media (max-width: 768px) {
		.book-session {
			padding: 3rem 1.5rem;
		}

		h2 {
			font-size: 2rem;
		}
	}
</style>
