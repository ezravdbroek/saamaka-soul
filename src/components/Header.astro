---
---

<header>
	<div class="header-container">
		<a href="/" class="logo" aria-label="Sáamaka Soul Home">
			<img src="/logo.png" alt="Sáamaka Soul" width="90" height="90" />
		</a>
		<span class="label">PRIVATE ADVISORY</span>
	</div>
</header>

<style>
	header {
		background-color: #000000;
		padding: 2rem 4rem;
	}

	.header-container {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo img {
		display: block;
		width: 90px;
		height: 90px;
	}

	.label {
		font-family: 'Inter', sans-serif;
		font-size: 0.7rem;
		font-weight: 400;
		letter-spacing: 0.25em;
		color: #c9a227;
		text-transform: uppercase;
	}

	@media (max-width: 768px) {
		header {
			padding: 1.5rem;
		}

		.logo img {
			width: 70px;
			height: 70px;
		}

		.label {
			font-size: 0.65rem;
		}
	}
</style>
