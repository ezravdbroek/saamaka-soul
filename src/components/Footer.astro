---
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="footer-container">
		<div class="footer-brand">
			<a href="/" class="logo">Sáamaka Soul Trust</a>
			<p class="tagline">From roots to remembrance</p>
		</div>

		<div class="footer-links">
			<div class="footer-column">
				<h4>Navigatie</h4>
				<a href="/">Home</a>
				<a href="/about">Over mij</a>
				<a href="/coaching">Coaching</a>
				<a href="/shop">Shop</a>
				<a href="/projects">Projecten</a>
			</div>
			<div class="footer-column">
				<h4>Contact</h4>
				<a href="/booking">Boek een sessie</a>
				<p class="email">info@saamakasoul.com</p>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {currentYear} Sáamaka Soul Trust. Alle rechten voorbehouden.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		background-color: #000000;
		padding: 4rem;
		border-top: 1px solid #1a1a1a;
	}

	.footer-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer-brand {
		margin-bottom: 3rem;
	}

	.footer-brand .logo {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-style: italic;
		color: #ffffff;
		display: block;
		margin-bottom: 0.5rem;
	}

	.footer-brand .tagline {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1rem;
		font-style: italic;
		color: #c9a227;
	}

	.footer-links {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3rem;
		max-width: 400px;
	}

	.footer-column h4 {
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		font-weight: 400;
		color: #ffffff;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1rem;
	}

	.footer-column a,
	.footer-column p {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		font-weight: 300;
		color: #666666;
		display: block;
		margin-bottom: 0.5rem;
		transition: color 0.3s ease;
	}

	.footer-column a:hover {
		color: #c9a227;
	}

	.footer-column .email {
		color: #a0a0a0;
	}

	.footer-bottom {
		padding-top: 2rem;
		border-top: 1px solid #1a1a1a;
	}

	.footer-bottom p {
		font-family: 'Inter', sans-serif;
		font-size: 0.8rem;
		color: #666666;
	}

	@media (max-width: 768px) {
		footer {
			padding: 2rem 1.5rem;
		}

		.footer-links {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
