---
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="footer-container">
		<div class="footer-top">
			<div class="footer-brand">
				<a href="/" class="logo">Sáamaka Soul Trust</a>
				<p class="tagline">From roots to remembrance</p>
			</div>

			<div class="footer-column">
				<h4>Navigatie</h4>
				<a href="/">Home</a>
				<a href="/about">Over mij</a>
				<a href="/coaching">Coaching</a>
				<a href="/shop">Shop</a>
				<a href="/projects">Projecten</a>
			</div>

			<div class="footer-column">
				<h4>Services</h4>
				<a href="/coaching">Life coaching</a>
				<a href="/shop">Spiritual t-shirts</a>
				<a href="/projects">Projecten</a>
				<a href="/booking">Boek een sessie</a>
			</div>

			<div class="footer-column">
				<h4>Contact</h4>
				<a href="/booking">Boek een sessie</a>
				<p class="email">info@saamakasoul.com</p>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {currentYear} Sáamaka Soul Trust. Alle rechten voorbehouden.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		background-color: #000000;
		padding: 4rem;
		border-top: 1px solid #1a1a1a;
	}

	.footer-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer-top {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3rem;
		align-items: start;
	}

	.footer-brand .logo {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-style: italic;
		color: #ffffff;
		display: block;
		margin-bottom: 0.5rem;
		text-decoration: none;
	}

	.footer-brand .tagline {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1rem;
		font-style: italic;
		color: #c9a227;
	}

	.footer-column h4 {
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		font-weight: 500;
		color: #c9a227 !important;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1.25rem;
	}

	.footer-column a {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		font-weight: 300;
		color: #ffffff !important;
		display: block;
		margin-bottom: 0.75rem;
		transition: color 0.3s ease;
		text-decoration: none;
	}

	.footer-column a:hover {
		color: #c9a227 !important;
	}

	.footer-column .email {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		font-weight: 300;
		color: #ffffff !important;
		display: block;
		margin-bottom: 0.75rem;
	}

	.footer-bottom {
		padding-top: 2rem;
		border-top: 1px solid #1a1a1a;
		text-align: center;
	}

	.footer-bottom p {
		font-family: 'Inter', sans-serif;
		font-size: 0.8rem;
		color: #666666;
	}

	@media (max-width: 768px) {
		footer {
			padding: 2rem 1.5rem;
		}

		.footer-top {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.footer-brand {
			grid-column: span 2;
			text-align: center;
			margin-bottom: 1rem;
		}

		.footer-column {
			text-align: center;
		}
	}
</style>
