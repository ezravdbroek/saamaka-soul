---
---

<footer>
	<div class="footer-container">
		<div class="footer-logo">
			<img src="/logo.svg" alt="Sáamaka Soul" width="60" height="60" />
		</div>
		<h2 class="footer-name">Sáamaka Soul</h2>
		<p class="footer-subtitle">Private Identity & Leadership Advisory</p>
		<a href="mailto:info@saamakasoul.com" class="footer-email">
			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13L2 4"/></svg>
			info@saamakasoul.com
		</a>
		<div class="footer-divider"></div>
	</div>
</footer>

<style>
	footer {
		background-color: #000000;
		padding: 5rem 4rem 3rem;
		border-top: 1px solid #1a1a1a;
	}

	.footer-container {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1rem;
	}

	.footer-logo img {
		display: block;
		width: 60px;
		height: 60px;
		margin-bottom: 0.5rem;
	}

	.footer-name {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-weight: 400;
		font-style: italic;
		color: #ffffff;
	}

	.footer-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 0.75rem;
		font-weight: 300;
		color: #aaaaaa;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.footer-email {
		font-family: 'Inter', sans-serif;
		font-size: 0.8rem;
		font-weight: 300;
		color: #aaaaaa;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		transition: color 0.3s ease;
		margin-top: 0.5rem;
	}

	.footer-email:hover {
		color: #ffffff;
	}

	.footer-divider {
		width: 60px;
		height: 1px;
		background-color: #333333;
		margin-top: 2rem;
	}

	@media (max-width: 768px) {
		footer {
			padding: 3rem 1.5rem 2rem;
		}

		.footer-logo img {
			width: 48px;
			height: 48px;
		}

		.footer-name {
			font-size: 1.3rem;
		}
	}
</style>
